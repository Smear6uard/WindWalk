# WindWalk backend environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to git (it's in .gitignore).
# The app will fall back to mock weather data if OPENWEATHERMAP_API_KEY is missing.

# Current Chicago conditions (weather.py). Get it: openweathermap.org → account → API keys
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Frontend geocoding (used by P5, not the backend directly). Get it: account.mapbox.com → tokens
MAPBOX_TOKEN=your_mapbox_token_here
