# Mapbox token for geocoding (address search) and map tiles
# Get one at: https://account.mapbox.com → Access tokens
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Backend API URL. For mobile: use your PC's Wi‑Fi IP (ipconfig → IPv4 under Wi‑Fi).
# Avoid 172.17.x / 172.31.x (Docker/WSL) — phone can't reach those. Use 192.168.x.x.
# After changing: restart Expo with cache clear: npx expo start -c
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8000
